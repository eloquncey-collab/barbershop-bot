# ============================================================
# Barbershop Bot - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ----- REQUIRED -----

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Comma-separated list of admin Telegram IDs (get via @userinfobot)
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# ----- DATABASE (choose one) -----

# Option A: SQLite (default, no setup needed)
# Leave DATABASE_URL empty to use SQLite at DB_PATH
DB_PATH=/app/data/barbershop.db

# Option B: PostgreSQL (recommended for production / Railway)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ----- OPTIONAL -----

# Timezone (IANA format)
TIMEZONE=Asia/Almaty

# Redis for FSM storage (recommended for multi-instance / Railway)
# REDIS_URL=redis://:password@host:6379/0
REDIS_URL=

# Master Telegram IDs (to notify masters about bookings)
# Format: MasterName1=telegram_id1,MasterName2=telegram_id2
# Example: MASTER_IDS=Алибек=111111111,Дамир=222222222
MASTER_IDS=

# Minimum minutes in advance a booking can be made (default: 60)
MIN_BOOKING_ADVANCE_MINUTES=60

# Proxy URL (if Telegram is blocked in your country)
# PROXY_URL=http://proxy.example.com:8080
PROXY_URL=
