# ==================================================
# Nastrojki bota - zapolnite pered zapuskom
# Skopiruyte .env.example -> .env i zapolnite danye
# ==================================================

# Token bota - poluchit u @BotFather
BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Vash Telegram ID (esli neskolko - cherez zapyatuyu: 111,222)
# Uznat ID: napishite @userinfobot v Telegram
ADMIN_IDS=123456789

# Telegram ID masterov (format: Alibek=111,Daniyar=222)
# Ostavte pustym esli ne nuzhno
MASTER_IDS=

# Chasovoj poyas (Asia/Almaty, Europe/Moscow ...)
TIMEZONE=Asia/Almaty

# Put k BD - NE menyajte pri Docker
# RAILWAY FIX: всегда использовать абсолютный путь к примонтированному volume
DB_PATH=/app/data/barbershop.db

# PostgreSQL (Railway auto-injects this when PG plugin is added)
# Leave empty for SQLite (local dev)
DATABASE_URL=

# Redis for FSM storage (optional, Railway Redis plugin)
# Leave empty to use FileStorage
REDIS_URL=
