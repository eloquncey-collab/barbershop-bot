# Force LF line endings for Linux/Docker files
# Prevents Windows CRLF corruption of shell scripts
*.sh         text eol=lf
entrypoint.sh text eol=lf
Dockerfile   text eol=lf
docker-compose.yml text eol=lf
.dockerignore text eol=lf

# Python files - LF
*.py text eol=lf

# Config files
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.env* text eol=lf
